<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFramework>net6.0</TargetFramework>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
        <NoWarn>$(NoWarn);1591;NU1605;NU1801;NU1901</NoWarn>
    </PropertyGroup>

    <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Debug|AnyCPU'">
        <GenerateDocumentationFile>true</GenerateDocumentationFile>
    </PropertyGroup>

    <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Release|AnyCPU'">
        <GenerateDocumentationFile>true</GenerateDocumentationFile>
    </PropertyGroup>

    <Target Name="CopyDllAndXml" AfterTargets="Build">
        <ItemGroup>
            <OutputFiles Include="$(TargetDir)$(AssemblyName).dll" />
            <OutputFiles Include="$(TargetDir)$(AssemblyName).xml" />
        </ItemGroup>
        <Copy SourceFiles="@(OutputFiles)" DestinationFolder="$(ProjectDir)..\dlls\" SkipUnchangedFiles="true" />
    </Target>

    <ItemGroup>
        <ProjectReference Include="..\YogoPop.Component.Auth\YogoPop.Component.Auth.csproj" />
        <ProjectReference Include="..\YogoPop.Component.Cache\YogoPop.Component.Cache.csproj" />
        <ProjectReference Include="..\YogoPop.Component.Security\YogoPop.Component.Security.csproj" />
        <ProjectReference Include="..\YogoPop.Core\YogoPop.Core.csproj" />
        <ProjectReference Include="..\YogoPop.DB.Define\YogoPop.DB.Define.csproj" />
    </ItemGroup>

</Project>
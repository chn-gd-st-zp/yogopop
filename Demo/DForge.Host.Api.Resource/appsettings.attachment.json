{
  "AttachmentSettings": {
    "Basic": {
      "PathMode": "REF",
      "PathAddr": "/attachment",
      "Handlers": [
        {
          "Handler": "PIC",
          "Exts": [ "jpg", "jpeg", "png", "heic", "heif" ]
        },
        {
          "Handler": "DOC",
          "Exts": [ "doc", "docs", "xls", "xlsx", "csv", "pdf" ]
        },
        {
          "Handler": "Media",
          "Exts": [ "mp4", "aac", "mov", "3gp", "mkv" ]
        }
      ],
      "ExtMapping": {
        "vndopenxmlformats-officedocumentwordprocessingmldocument": "docx",
        "vndopenxmlformats-officedocumentspreadsheetmlsheet": "xlsx"
      }
    },
    "Operations": [
      {
        "Key": "Other",
        "Handlers": [
          {
            "Handler": "PIC",
            "MaxKB": 10240,
            "Args": [
              "Type:Large|Suffix:l|ShrinkTo:80",
              "Type:Medium|Suffix:m|ShrinkTo:50",
              "Type:Small|Suffix:s|ShrinkTo:25"
            ]
          },
          {
            "Handler": "DOC",
            "MaxKB": 10240,
            "Args": []
          },
          {
            "Handler": "Media",
            "MaxKB": 10240,
            "Args": []
          }
        ]
      },
      {
        "Key": "TextContent",
        "Handlers": [
          {
            "Handler": "PIC",
            "MaxKB": 10240,
            "Args": [
              "Type:Large|Suffix:l|ShrinkTo:80",
              "Type:Medium|Suffix:m|ShrinkTo:50",
              "Type:Small|Suffix:s|ShrinkTo:25"
            ]
          },
          {
            "Handler": "DOC",
            "MaxKB": 10240,
            "Args": []
          },
          {
            "Handler": "Media",
            "MaxKB": 10240,
            "Args": []
          }
        ]
      },
      {
        "Key": "Icon",
        "Handlers": [
          {
            "Handler": "PIC",
            "MaxKB": 1024,
            "Args": []
          }
        ]
      }
    ]
  }
}